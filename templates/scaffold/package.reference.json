{
  "name": "haatz-r6-miniapp-panel",
  "version": "1.0.0",
  "license": "MIT",
  "scripts": {
    "lint": "eslint src test --ext .js,.jsx,.ts,.tsx --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "start:tuya": "ray start -t tuya --verbose",
    "readResource": "node scripts/read.js",
    "build:tuya": "ray build -t tuya --verbose"
  },
  "dependencies": {
    "@ray-js/panel-sdk": "1.13.1-ignoredp.14",
    "@ray-js/ray": "^1.5.47",
    "@ray-js/lamp-color-wheel": "^1.1.6",
    "@ray-js/ray-error-catch": "^0.0.19",
    "@ray-js/smart-ui": "^2.13.2",
    "core-js": "^3.23.5",
    "lodash-es": "^4.17.21"
  },
  "devDependencies": {
    "@commitlint/cli": "^7.2.1",
    "@commitlint/config-conventional": "^9.0.1",
    "@ray-js/cli": "^1.5.47",
    "@resvg/resvg-js": "^2.6.2",
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^12.1.5",
    "@types/lodash-es": "^4.17.6",
    "@types/react": "^17.0.24",
    "@types/react-dom": "^17.0.9",
    "@vitejs/plugin-react": "^4.2.0",
    "eslint-config-tuya-panel": "^0.4.1",
    "eslint-plugin-literal-check": "^0.1.2",
    "eslint-plugin-prettier": "^3.0.1",
    "husky": "^1.2.0",
    "jsdom": "^24.0.0",
    "lint-staged": "^10.2.11",
    "prettier": "^1.16.4",
    "react": "^17.0.2",
    "react-dom": "^17.0.2",
    "typescript": "^4.4.3",
    "vitest": "^1.6.0"
  },
  "husky": {
    "hooks": {
      "commit-msg": "commitlint -E HUSKY_GIT_PARAMS --config commitlint.config.js",
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "git add"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write",
      "git add"
    ]
  },
  "resolutions": {
    "@ray-js/panel-sdk": "1.13.1-ignoredp.14",
    "@types/react": "^17.0.24",
    "follow-redirects": "1.15.6",
    "@jridgewell/gen-mapping": "0.3.8"
  }
}
