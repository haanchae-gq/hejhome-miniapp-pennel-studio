          "dp": "temp_set",
          "labelKey": "temp_set_label"
        },
        {
          "id": "t3",
          "type": "hvacModeTabs",
          "dp": "mode"
        },
        {
          "id": "t4",
          "type": "metric",
          "dp": "temp_current",
          "labelKey": "temp_cur_label"
        },
        {
          "id": "t5",
          "type": "humidityRing",
          "dp": "humidity",
          "labelKey": "humid_label"
        }
      ]
    }
