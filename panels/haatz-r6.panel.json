      "toggleOff": "#4A4A55",
      "powerOff": "#182233", "dockGlyph": "#8A8A8A",
      "inactive": "#5A5A5A"
    },
    "aqColor": { "good": "#3B82F6", "normal": "#22C55E", "bad": "#F0A020", "very_bad": "#EF4444" },
    "opacity": { "offline": 0.5, "disabled": 0.35, "pressed": 0.6 }
  },

