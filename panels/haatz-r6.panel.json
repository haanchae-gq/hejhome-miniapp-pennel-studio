  "dps": [
    { "id": 1,   "code": "switch",              "camel": "switch",             "name": "전원",           "mode": "rw", "type": "bool",   "semantic": "power" },
    { "id": 3,   "code": "mode",                "camel": "mode",               "name": "모드",           "mode": "rw", "type": "enum",   "range": ["bypass", "cook", "clean_ventilation", "clean_rotation"], "semantic": "mode-select" },
    { "id": 21,  "code": "air_quality",         "camel": "airQuality",         "name": "공기질",         "mode": "ro", "type": "enum",   "range": ["very_bad", "bad", "normal", "good"], "semantic": "grade-badge" },
    { "id": 101, "code": "fan_level",           "camel": "fanLevel",           "name": "풍량",           "mode": "rw", "type": "enum",   "range": ["low", "mid", "high", "auto"], "semantic": "level-dial" },
    { "id": 105, "code": "humidity_value",      "camel": "humidityValue",      "name": "현재 습도",      "mode": "ro", "type": "value",  "min": 0, "max": 100,  "scale": 0, "step": 1, "unit": "%",    "semantic": "metric" },
    { "id": 107, "code": "fault_remind",        "camel": "faultRemind",        "name": "오류 알람",      "mode": "ro", "type": "fault",  "label": ["error_1", "error_2", "error_3", "error_4", "error_5", "error_6", "error_7"], "semantic": "unrendered", "note": "패널이 그리지 않는다 — 서버 푸시가 담당" },
    { "id": 109, "code": "filter_reset_notice", "camel": "filterResetNotice",  "name": "필터 교체",      "mode": "rw", "type": "enum",   "range": ["reset_complete"], "semantic": "action" },
    { "id": 111, "code": "temp_current",        "camel": "tempCurrent",        "name": "현재 온도",      "mode": "ro", "type": "value",  "min": 0, "max": 100,  "scale": 0, "step": 1, "unit": "℃",    "semantic": "metric" },
    { "id": 130, "code": "fine_dust",           "camel": "fineDust",           "name": "미세먼지 농도",  "mode": "ro", "type": "value",  "min": 0, "max": 500,  "scale": 0, "step": 1, "unit": "㎍/㎥", "semantic": "sensor-row" },
    { "id": 131, "code": "co2",                 "camel": "co2",                "name": "이산화탄소 농도","mode": "ro", "type": "value",  "min": 0, "max": 5000, "scale": 0, "step": 1, "unit": "ppm",  "semantic": "sensor-row" },
    { "id": 132, "code": "on_schedule",         "camel": "onSchedule",         "name": "켜짐시간",       "mode": "rw", "type": "string", "maxlen": 5, "semantic": "schedule-time" },
    { "id": 133, "code": "off_schedule",        "camel": "offSchedule",        "name": "꺼짐시간",       "mode": "rw", "type": "string", "maxlen": 5, "semantic": "schedule-time" },
    { "id": 134, "code": "on_schdule_switch",   "camel": "onScheduleSwitch",   "name": "켜짐예약",       "mode": "rw", "type": "bool",   "semantic": "toggle", "note": "identifier misspelling is intentional — matches DP definition" },
    { "id": 135, "code": "off_schedule_switch", "camel": "offScheduleSwitch",  "name": "꺼짐예약",       "mode": "rw", "type": "bool",   "semantic": "toggle" }
