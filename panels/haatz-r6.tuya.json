    { "code": "fan_level",           "dp_id": 101, "type": "enum",   "values": "{\"range\":[\"low\",\"mid\",\"high\",\"auto\"]}" },
    { "code": "filter_reset_notice", "dp_id": 109, "type": "enum",   "values": "{\"range\":[\"reset_complete\"]}" },
